# ============================================
# Messenger — Переменные окружения
# ============================================
# Скопируйте этот файл в .env и измените значения
# cp .env.example .env

# Приложение
APP_NAME=Messenger
DEBUG=false
LOG_LEVEL=INFO

# База данных (не меняйте для SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# JWT — ОБЯЗАТЕЛЬНО смените на случайную строку!
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Файлы
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=25

# Invite-коды
INVITE_CODE_LENGTH=8
INVITE_CODE_MAX_USES=1

# Rate limiting (запросов в секунду на IP)
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_SECONDS=1

# CORS origins (через запятую)
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000

# Админ-код для первого входа
ADMIN_INVITE_CODE=ADMIN-SETUP-CODE

# Домен для Caddy (замените на ваш)
MESSENGER_DOMAIN=your-domain.com
