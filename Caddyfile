# Замените your-domain.com на ваш реальный домен
your-domain.com {
    # Backend API (должен идти ДО /*)
    handle /api/* {
        reverse_proxy app:8000
    }

    # WebSocket (должен идти ДО /*)
    handle /ws/* {
        reverse_proxy app:8000
    }

    # Health check (должен идти ДО /*)
    handle /health {
        reverse_proxy app:8000
    }

    # Frontend (статические файлы) — должен быть последним
    handle /* {
        reverse_proxy frontend:80
    }

    encode gzip
    log {
        output stdout
        format json
    }
}

# Локальная разработка (без HTTPS)
http://localhost {
    handle /api/* {
        reverse_proxy app:8000
    }

    handle /ws/* {
        reverse_proxy app:8000
    }

    handle /health {
        reverse_proxy app:8000
    }

    handle /* {
        reverse_proxy frontend:80
    }
}
